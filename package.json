{
  "name": "oh-my-openharness",
  "version": "0.1.6",
  "type": "module",
  "description": "Bun-first runtime setup, editor, and export orchestration for AI coding agent workflows",
  "license": "MIT",
  "files": [
    "bin/oh-my-openharness",
    "bin/harness-editor",
    "src",
    "README.md",
    "tsconfig.json",
    "index.html",
    "vite.config.ts"
  ],
  "bin": {
    "oh-my-openharness": "bin/oh-my-openharness",
    "harness-editor": "bin/harness-editor"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "ci": "bunx tsc --noEmit && bun run test && npm pack --dry-run",
    "test": "bun test --timeout 180000 tests/*.test.ts",
    "typecheck": "bunx tsc --noEmit",
    "proof:harness-editor": "bun run scripts/harness-editor-golden-path.ts",
    "demo": "bun run src/index.ts demo --name demo-harness --prompt \"Create a review harness with approvals, MCP server support, and retry loop\"",
    "build:web": "vite build",
    "dev:web": "vite --host 127.0.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "latest",
    "typescript": "^5.9.2",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
